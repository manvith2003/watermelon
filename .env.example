# ── GitHub ──────────────────────────────────────────────────────────────────
# Personal access token with: repo, read:user scopes
GITHUB_TOKEN=ghp_your_token_here

# Default repo if not passed via --repo flag (owner/repo format)
DEFAULT_REPO=your-username/your-repo

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Uses litellm — supports any provider. Free options listed below.

# Option A: Groq (FREE — fast inference)
LLM_MODEL=groq/llama-3.3-70b-versatile
GROQ_API_KEY=gsk_your_groq_key_here

# Option B: Anthropic Claude
# LLM_MODEL=claude-3-5-haiku-20241022
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# Option C: OpenAI
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-your_key_here

# ── Memory ───────────────────────────────────────────────────────────────────
# Where the SQLite memory DB is stored (defaults to ~/.github_agent/memory.db)
# AGENT_DB_PATH=/path/to/memory.db
